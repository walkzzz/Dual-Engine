# Dual-Engine CLI Configuration Example
# Copy this file to .opencode.json and fill in your API key

{
  "providers": {
    "moonshot": {
      "apiKey": "YOUR_MOONSHOT_API_KEY",
      "disabled": false
    }
  },
  "agents": {
    "coder": {
      "model": "moonshot.moonshot-v1-32k",
      "maxTokens": 4096
    }
  }
}